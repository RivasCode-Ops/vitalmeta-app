# Required (Docker Compose — MySQL local)
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PASSWORD=change_me_user
JWT_SECRET=generate-with-openssl-rand-hex32

# Required (Railway — MySQL add-on provides DATABASE_URL)
# DATABASE_URL is auto-set by Railway MySQL plugin
# JWT_SECRET=...

# Required (always — LLM API key for AI features)
# BUILT_IN_FORGE_API_KEY=...

# Optional (for OAuth SSO)
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=

# Optional (for AI features via Manus Forge)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional (CORS whitelist for custom domain)
CORS_ORIGIN=

# Optional (port override)
PORT=3000
